---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Agent Harness Extensions",
  description = "A daily-refreshed directory of MCP servers, skills, plugins, and agents for agent harnesses.",
} = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const rssHref = new URL("rss.xml", `https://example.com${basePath}`).pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Agent Harness Extensions Feed"
      href={rssHref}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
